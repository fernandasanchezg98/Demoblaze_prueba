    "cypress": "15.18.1",
    "cypress-mochawesome-reporter": "4.0.2",
    "esbuild": "0.28.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.js"
    ]
